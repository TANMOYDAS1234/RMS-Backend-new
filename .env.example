MONGODB_URI=mongodb+srv://user:pass@cluster0.mongodb.net/rms?retryWrites=true&w=majority
DB_NAME=rms
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=3000

# Firebase Cloud Messaging (FCM HTTP v1)
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FCM_PROJECT_ID=your-firebase-project-id
# Paste the entire service account JSON as a single-line string (escape quotes)
FCM_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
